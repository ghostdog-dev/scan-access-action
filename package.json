{
  "name": "scan-access-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for scan-access WCAG accessibility audit",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "ncc build src/index.ts --license licenses.txt --minify",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
